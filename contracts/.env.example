# Copy to project root `.env` or `contracts/.env` (both are loaded by Hardhat; gitignored).

# BSC deployer — 0x-prefixed hex (never commit real keys)
DEPLOYER_PRIVATE_KEY=

# Optional RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/

# Optional: full-supply recipient (default treasury 0x5AD2…428D8)
BXAUT_TREASURY=

# Etherscan API V2 (recommended): one key for BSC + many chains — create at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# Legacy BscScan-only key (used if ETHERSCAN_API_KEY is empty): https://bscscan.com/myapikey
BSCSCAN_API_KEY=
# After deploy — verify on BscScan (args must match deploy tx):
# SHOVEL_NFT_ADDRESS=0x...  NFT_METADATA_BASE_URI=http://127.0.0.1:5173/nft-metadata/
# SHOVEL_OWNER=0x...  (same as deployer passed as initialOwner)
# npm run verify:shovel
#
# Manual verify on BscScan (single-file .sol paste fails on @openzeppelin imports):
#   npm run export:bscscan-shovel
#   Upload: bscscan-ShovelNFT-standard-input.json (repo root) OR contracts/bscscan-ShovelNFT-standard-input.json
#   Type: Solidity (Standard JSON Input). Do not upload the whole build-info/*.json file.
#
# GitHub Pages + wallet NFT images: after Pages URL is live, owner runs setBaseURI to the same origin, e.g.
#   NFT_METADATA_BASE_URI=https://YOUR_USER.github.io/YOUR_REPO/nft-metadata/
#   npm run shovel:set-baseuri
# (See README.md — CI generates metadata with NFT_SITE_BASE automatically.)

# Shovel NFT — metadata & deploy (see scripts/generate-shovel-metadata.cjs)
# Public HTTPS origin where `npm run build` is hosted (serves /nft/*.png and /nft-metadata/*.json).
NFT_SITE_BASE=
# Or set full base for tokenURI (overrides NFT_SITE_BASE for deploy only):
NFT_METADATA_BASE_URI=
# Optional: override treasury for NFT mint USDT (default 0x5AD2…428D8)
SHOVEL_TREASURY=
# Testnet only — BSC testnet USDT mock if not using default
BSC_TESTNET_USDT_ADDRESS=

# PowerShell: use $env:VAR = 'value' (not cmd's `set VAR=value`).
# $env:DEPLOYER_PRIVATE_KEY = '0x...'
# $env:BSC_RPC_URL = 'https://bsc-dataseed.binance.org/'
# npm run deploy:bxaut
